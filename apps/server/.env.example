# ============================================================
# JadiBot Enterprise — Backend Environment Variables
# Copy to .env and fill in values before running the server.
# ============================================================

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Public base path for the REST API (the frontend prepends the host).
API_PREFIX=/api

# ── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://jadibot:jadibot@localhost:5432/jadibot?schema=public

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT / Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_dev_access_secret_change_me_dev_access_secret
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_change_me_dev_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ── Cookies ─────────────────────────────────────────────────
AUTH_COOKIE_NAME=jb_refresh
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:3000

# ── WhatsApp engine ─────────────────────────────────────────
WA_SESSION_PATH=./storage/sessions
WA_MAX_RECONNECT_ATTEMPTS=10

# ── Google OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── Bootstrap admin (created by `npm run prisma:seed`) ──────
SEED_ADMIN_EMAIL=admin@jadibot.local
SEED_ADMIN_PASSWORD="Admin#12345"
SEED_ADMIN_NAME=Super Admin
