# ============================================================
# JadiBot Enterprise — Environment Variables
# Copy this file to .env.local and fill in ALL values.
# NEVER commit .env.local to version control.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="JadiBot Enterprise"

# ── API & Socket ─────────────────────────────────────────────
# The base URL for the backend REST API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# The WebSocket server URL (Socket.IO)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ── Auth (Secrets — never expose publicly) ───────────────────
# A cryptographically random string (>= 64 chars) for signing sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_HEX

# JWT signing secret — different from SESSION_SECRET
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# JWT access token lifetime (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# JWT refresh token lifetime (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie ───────────────────────────────────────────────────
AUTH_COOKIE_NAME=jb_auth
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Database (future backend) ────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/jadibot

# ── Redis (future session store) ─────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Email (future notifications) ─────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@jadibot.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="JadiBot <noreply@jadibot.com>"

# ── Feature Flags ────────────────────────────────────────────
# NEXT_PUBLIC_ENABLE_2FA=true
# NEXT_PUBLIC_ENABLE_AUDIT_LOG=true
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# ── Observability (optional) ─────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
